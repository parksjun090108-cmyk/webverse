generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                      String             @id @default(cuid())
  nickname                String
  email                   String             @unique
  passwordHash            String
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  userSites               UserSite[]
  histories               History[]
  discoveries             SiteDiscovery[]
  constellations          Constellation[]
  createdSites            Site[]             @relation("CreatedSites")
  extensionPairing        ExtensionPairing?
  extensionSessions       ExtensionSession[]
  initialImportAt         DateTime?
  universeVisibility      String             @default("PRIVATE")
  publicSlug              String?            @unique
  universePublishedAt     DateTime?
  universeHiddenAt        DateTime?
  universeHiddenReason    String?
  universeReportsMade     UniverseReport[]   @relation("UniverseReportReporter")
  universeReportsReceived UniverseReport[]   @relation("UniverseReportTarget")
  universeBlocksMade      UniverseBlock[]    @relation("UniverseBlockOwner")
  universeBlocksReceived  UniverseBlock[]    @relation("UniverseBlockTarget")
}

model Admin {
  id               String            @id @default(cuid())
  name             String
  email            String            @unique
  passwordHash     String
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  approvalRequests ApprovalRequest[]
  auditLogs        AdminAuditLog[]
  universeReports  UniverseReport[]
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String
  details    String?
  createdAt  DateTime @default(now())
  admin      Admin    @relation(fields: [adminId], references: [id], onDelete: Restrict)

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String
  anchorX   Float
  anchorY   Float
  anchorZ   Float
  sites     Site[]
  createdAt DateTime @default(now())
}

model Site {
  id                     String              @id @default(cuid())
  name                   String
  domain                 String              @unique
  normalizedUrl          String              @unique
  faviconUrl             String?
  description            String?
  themeColor             String              @default("#8992aa")
  status                 String              @default("UNLISTED")
  verified               Boolean             @default(false)
  categoryId             String?
  category               Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdById            String?
  createdBy              User?               @relation("CreatedSites", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  userSites              UserSite[]
  histories              History[]
  discoveries            SiteDiscovery[]
  constellationMap       ConstellationSite[]
  constellationEdgesFrom ConstellationEdge[] @relation("ConstellationEdgeFrom")
  constellationEdgesTo   ConstellationEdge[] @relation("ConstellationEdgeTo")
  approvalRequest        ApprovalRequest?

  @@index([status])
  @@index([categoryId])
}

model UserSite {
  userId          String
  siteId          String
  visitCount      Int      @default(0)
  favorite        Boolean  @default(false)
  browserFavorite Boolean  @default(false)
  positionX       Float    @default(0)
  positionY       Float    @default(0)
  positionZ       Float    @default(0)
  lastVisit       DateTime @default(now())
  discoveredAt    DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@id([userId, siteId])
  @@index([userId, lastVisit])
}

model SiteDiscovery {
  userId       String
  siteId       String
  discoveredAt DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  site         Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@id([userId, siteId])
  @@index([siteId])
}

model History {
  id        String   @id @default(cuid())
  userId    String
  siteId    String
  action    String
  sessionId String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, sessionId])
}

model Constellation {
  id              String              @id @default(cuid())
  userId          String
  name            String
  patternKey      String
  strength        Int                 @default(1)
  occurrenceCount Int                 @default(3)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  sites           ConstellationSite[]
  edges           ConstellationEdge[]

  @@unique([userId, patternKey])
}

model ConstellationSite {
  constellationId String
  siteId          String
  sequence        Int
  constellation   Constellation @relation(fields: [constellationId], references: [id], onDelete: Cascade)
  site            Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@id([constellationId, sequence])
  @@index([siteId])
}

model ConstellationEdge {
  constellationId String
  fromSiteId      String
  toSiteId        String
  count           Int           @default(3)
  constellation   Constellation @relation(fields: [constellationId], references: [id], onDelete: Cascade)
  fromSite        Site          @relation("ConstellationEdgeFrom", fields: [fromSiteId], references: [id], onDelete: Cascade)
  toSite          Site          @relation("ConstellationEdgeTo", fields: [toSiteId], references: [id], onDelete: Cascade)

  @@id([constellationId, fromSiteId, toSiteId])
  @@index([fromSiteId])
  @@index([toSiteId])
}

model ApprovalRequest {
  id             String    @id @default(cuid())
  siteId         String    @unique
  status         String    @default("REQUESTED")
  requestedAt    DateTime  @default(now())
  resolvedAt     DateTime?
  resolvedById   String?
  resolutionNote String?
  site           Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  resolvedBy     Admin?    @relation(fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([status, requestedAt])
  @@index([resolvedById])
}

model ExtensionPairing {
  id        String   @id @default(cuid())
  userId    String   @unique
  codeHash  String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExtensionSession {
  id         String                @id @default(cuid())
  userId     String
  tokenHash  String                @unique
  deviceName String
  createdAt  DateTime              @default(now())
  lastSeenAt DateTime?
  revokedAt  DateTime?
  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  events     ExtensionVisitEvent[]

  @@index([userId, revokedAt])
}

model ExtensionVisitEvent {
  id        String           @id
  sessionId String
  domain    String
  visitedAt DateTime
  accepted  Boolean
  createdAt DateTime         @default(now())
  session   ExtensionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, visitedAt])
}

model UniverseReport {
  id             String    @id @default(cuid())
  reporterUserId String
  targetUserId   String
  reason         String
  details        String?
  status         String    @default("OPEN")
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?
  resolvedById   String?
  reporter       User      @relation("UniverseReportReporter", fields: [reporterUserId], references: [id], onDelete: Cascade)
  target         User      @relation("UniverseReportTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  resolvedBy     Admin?    @relation(fields: [resolvedById], references: [id], onDelete: SetNull)

  @@unique([reporterUserId, targetUserId])
  @@index([status, createdAt])
  @@index([targetUserId])
  @@index([resolvedById])
}

model UniverseBlock {
  userId        String
  blockedUserId String
  createdAt     DateTime @default(now())
  user          User     @relation("UniverseBlockOwner", fields: [userId], references: [id], onDelete: Cascade)
  blockedUser   User     @relation("UniverseBlockTarget", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@id([userId, blockedUserId])
  @@index([blockedUserId])
}
